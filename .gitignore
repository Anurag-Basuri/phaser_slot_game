# =============================================
#  Sugar Rush 1000 — .gitignore
# =============================================

# === Frontend (Phaser / TypeScript) ===
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.pnp
frontend/.pnp.js

# === Math Engine (Python) ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv_bg/
.venv/
*.egg

# Math Engine — generated output (regenerated by run.py)
math-engine/games/*/library/books/
math-engine/games/*/library/books_compressed/
math-engine/games/*/library/lookup_tables/
math-engine/games/*/library/configs/
math-engine/games/*/library/forces/
math-engine/games/*/library/index.json

# === IDE / OS ===
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# === Logs ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Archives ===
sweet_cluster_1000.zip
bundle/
*.zip