# =============================================
#  Sugar Rush 1000 — .gitignore
# =============================================

# === Frontend (Phaser / TypeScript) ===
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.pnp
frontend/.pnp.js

# === Math Engine (Python) ===
__pycache__/
*.pyc
*.pyo
*.egg-info/
venv_bg/
.venv/
*.egg
.pytest_cache/
.coverage
htmlcov/

# Math Engine — generated output (regenerated by run.py)
math-engine/math/
math-engine/games/*/library/

# === Rust ===
math-engine/rust_optimizer/target/
math-engine/rust_optimizer/Cargo.lock

# === IDE / OS ===
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# === Logs ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# === Archives ===
sweet_cluster_1000.zip
bundle/
*.zip
frontend_upload.zip
math_engine_upload.zip