{
  "name": "sweet-cluster-1000",
  "description": "Sweet Cluster 1000 — 7x7 Cascading Cluster Pays Slot Game for Stake Engine",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite --open",
    "start": "vite --open",
    "build": "vite build",
    "bundle": "powershell -ExecutionPolicy Bypass -File scripts/bundle.ps1",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "math:sim": "python math-engine/run.py --sims 1000000 --export",
    "math:quick": "python math-engine/run.py --sims 100000",
    "prepare": "husky"
  },
  "dependencies": {
    "phaser": "3.90.0",
    "phaser-jsx": "0.13.7"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.2",
    "@commitlint/config-conventional": "20.4.2",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vite": "7.3.1",
    "vitest": "^4.1.2"
  },
  "private": true,
  "license": "MIT"
}
